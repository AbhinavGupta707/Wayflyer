# WS6 Voice — copy to keeper/apps/api/.env and fill in. Everything is optional:
# the API boots and the widget shows a text transcript + Yes/No even with none set.

# --- ElevenLabs (browser widget + the voice the phone call plays) ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=          # Conversational-AI agent id (for the live browser widget)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # 'Sarah' — used for the phone-call TTS clip
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- Twilio (real outbound call to a phone on stage) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=                # the +E.164 number you own and call FROM
DEMO_TO_NUMBER=               # optional default stage phone to call

# --- URLs ---
# Public https base Twilio can reach (an ngrok tunnel to :8000 in the demo).
#   ngrok http 8000   ->   https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=
# Where this API reaches itself for the in-process /respond hop (rarely changed).
SELF_BASE_URL=http://127.0.0.1:8000
